<UserControl x:Class="XamlLocalizationEditor.UserControls.MenuControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XamlLocalizationEditor.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="25" d:DesignWidth="800"
             
             xmlns:md="https://github.com/fantasticfiasco/mvvm-dialogs"
             md:DialogServiceViews.IsRegistered="True">
    
    <Grid>
        <Menu>
            <MenuItem Header="Файл">
                <MenuItem Header="Create new languages collection"/>
                <MenuItem Header="Open strings .xaml file"/>
                <MenuItem Header="Импорт">
                    <MenuItem Header="From .sln (.slnx) folder" Command="{Binding OpenResourcesCollectionCommand}"/>
                    <MenuItem Header="From .txt" Command="{Binding OpenTxtFileCommand}"/>
                </MenuItem>
                <MenuItem Header="Экспорт">
                    <MenuItem Header="To .xaml" Command="{Binding SaveResourcesToXamlCommand}"/>
                    <MenuItem Header="To .txt"/>
                    <MenuItem Header="To .csv" Visibility="Collapsed"/>
                </MenuItem>
            </MenuItem>
        </Menu>
    </Grid>
</UserControl>

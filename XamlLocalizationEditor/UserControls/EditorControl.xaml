<UserControl x:Class="XamlLocalizationEditor.UserControls.EditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:XamlLocalizationEditor.UserControls"
             xmlns:models="clr-namespace:XamlLocalizationEditor.Models"
             xmlns:vm="clr-namespace:XamlLocalizationEditor.ViewModels"
             xmlns:c="clr-namespace:XamlLocalizationEditor.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <Button>
                <Path Data="{DynamicResource save_svgrepo_comGeometry}" Fill="Black" 
              VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
            <Separator/>
            <Button>
                <Path Data="{DynamicResource plus_svgrepo_comGeometry}" Fill="Black" 
              VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
            <Button>
                <Path Height="24" Width="24"  Stretch="Fill"
              Data="{DynamicResource delete_svgrepo_comGeometry}" Fill="Black"
              VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
        </ToolBar>
        <Grid DockPanel.Dock="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="300" Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TreeView x:Name="tvLangs" Grid.Column="0" Margin="5" Width="300"
                      ItemsSource="{Binding Langs}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Resources}" DataType="{x:Type models:LanguageResources}">
                        <ContentPresenter Content="{Binding }" />
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectedItemChanged">
                        <i:InvokeCommandAction Command="{Binding SelectedItemChangedCommand}" 
                       CommandParameter="{Binding ElementName=tvLangs, Path=SelectedItem}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </TreeView>

            <GridSplitter Grid.Column="1" Width="2" Background="LightGray"/>

            <ContentControl x:Name="DataGridsCC" Grid.Column="2" Margin="5"
                    Content="{Binding Selected}" >
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:LanguagesEditorViewModel}">
                        <DataGrid ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True" CanUserDeleteRows="True" CanUserSortColumns="True" CanUserReorderColumns="False" CanUserResizeRows="False"
                          IsReadOnly="False"
                          Background="White" AlternatingRowBackground="#46C4C4C4"
                          HeadersVisibility="Column"
                          c:DataGridColumnsBehavior.ColumnsSource="{Binding Columns}">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="MinHeight" Value="24"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="MaxWidth" Value="250"/>
                                </Style>
                            </DataGrid.CellStyle>
                        </DataGrid>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type models:LanguageResources}">
                        <DataGrid Grid.Column="1" Margin="5" ItemsSource="{Binding Strings}"/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>

        </Grid>
    </DockPanel>
</UserControl>

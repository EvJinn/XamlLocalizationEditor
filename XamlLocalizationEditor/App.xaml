<Application x:Class="XamlLocalizationEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:XamlLocalizationEditor"
             xmlns:uc="clr-namespace:XamlLocalizationEditor.UserControls"
             xmlns:vm="clr-namespace:XamlLocalizationEditor.ViewModels">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Icons/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:MenuViewModel}">
                <uc:MenuControl/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EditorViewModel}">
                <uc:EditorControl/>
            </DataTemplate>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
